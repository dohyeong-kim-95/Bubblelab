{
  "name": "resistance-avalon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "simulate": "node ./scripts/simulate-games.mjs",
    "simulate:quick": "node ./scripts/simulate-games.mjs --iterations 25",
